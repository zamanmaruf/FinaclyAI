  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "verify-all": "tsx scripts/verify-all.ts",
    "verify:day6": "tsx scripts/verify-day6.ts",
    "test:api": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "test:perf": "echo 'Lighthouse CI not configured yet'",
    "ci:all": "npm run lint && npm run test:api && npm run test:e2e && npm run verify:day6",
    "stripe:seed:payout": "curl -X POST http://localhost:3000/api/stripe/seed-payout -H \"Authorization: Bearer ${SHARED_ADMIN_TOKEN:-test}\" -H \"Content-Type: application/json\"",
    "plaid:link-token": "curl -X POST http://localhost:3000/api/plaid/link-token -H \"Content-Type: application/json\" -d '{\"userId\":\"test-user-1\"}'",
    "plaid:sandbox-link": "curl -X POST http://localhost:3000/api/plaid/sandbox-link -H \"Authorization: Bearer ${SHARED_ADMIN_TOKEN:-test}\" -H \"Content-Type: application/json\""
  },
