{
  "extends": "next/core-web-vitals",
  "rules": {
    "react/no-unescaped-entities": "off",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": [
              "faker",
              "@faker-js/faker",
              "casual",
              "chance",
              "**/mocks/**",
              "**/mocks/*",
              "*mock*",
              "*faker*",
              "*@tests/fixtures*",
              "*seed*",
              "*play-data*"
            ],
            "message": "❌ PRODUCTION BUILD FAILURE: Mock/faker/seed imports are STRICTLY FORBIDDEN. Use only real test-mode API data from Stripe, Plaid sandbox, and QBO sandbox."
          }
        ]
      }
    ]
  }
}
