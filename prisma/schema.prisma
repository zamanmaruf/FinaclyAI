generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id               String            @id @default(cuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  name             String
  description      String?
  isActive         Boolean           @default(true)
  stripeCustomerId String?
  qboCustomerId    String?
  plaidItemId      String?
  bankTransactions BankTransaction[]
  matches          Match[]
  payoutItems      PayoutItem[]
  qboEntries       QboEntry[]

  @@map("accounts")
}

model BankTransaction {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  accountId       String
  externalId      String    @unique
  description     String
  amount          BigInt
  currency        String    @db.VarChar(3)
  transactionDate DateTime
  postedDate      DateTime?
  reference       String?
  bankName        String?
  accountNumber   String?
  routingNumber   String?
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  matches         Match[]

  @@index([accountId, transactionDate])
  @@index([amount, currency])
  @@index([externalId])
  @@map("bank_transactions")
}

model PayoutItem {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  accountId      String
  payoutId       String
  stripeChargeId String
  amount         BigInt
  currency       String   @db.VarChar(3)
  description    String?
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, payoutId])
  @@index([stripeChargeId])
  @@map("payout_items")
}

model QboEntry {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  accountId   String
  qboEntryId  String   @unique
  amount      BigInt
  currency    String   @db.VarChar(3)
  description String
  entryDate   DateTime
  entryType   String
  reference   String?
  matches     Match[]
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, entryDate])
  @@index([amount, currency])
  @@index([qboEntryId])
  @@map("qbo_entries")
}

model Match {
  id                String           @id @default(cuid())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  accountId         String
  status            String
  confidence        Float?
  notes             String?
  bankTransactionId String?
  qboEntryId        String?
  account           Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  qboEntry          QboEntry?        @relation(fields: [qboEntryId], references: [id])

  @@index([accountId, status])
  @@index([status, createdAt])
  @@map("matches")
}

model StripeAccount {
  id              String            @id @db.VarChar(64)
  defaultCurrency String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  balanceTxs      StripeBalanceTx[]
  charges         StripeCharge[]
  payouts         StripePayout[]
}

model StripeCharge {
  id            String        @id @db.VarChar(64)
  accountId     String
  customerId    String?       @db.VarChar(64)
  paymentIntent String?       @db.VarChar(64)
  amount        BigInt
  currency      String        @db.VarChar(8)
  fee           BigInt?
  net           BigInt?
  status        String        @db.VarChar(32)
  createdAtUnix Int
  createdAt     DateTime
  description   String?
  payoutId      String?       @db.VarChar(64)
  metadataJson  Json?
  updatedAt     DateTime      @updatedAt
  account       StripeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  payout        StripePayout? @relation("PayoutCharges", fields: [payoutId], references: [id])

  @@index([accountId])
  @@index([payoutId])
  @@index([createdAt])
}

model StripePayout {
  id                  String         @id @db.VarChar(64)
  accountId           String
  amount              BigInt
  currency            String         @db.VarChar(8)
  status              String         @db.VarChar(32)
  arrivalDateUnix     Int
  arrivalDate         DateTime
  description         String?
  statementDescriptor String?        @db.VarChar(255)
  metadataJson        Json?
  createdAtUnix       Int
  createdAt           DateTime
  updatedAt           DateTime       @updatedAt
  charges             StripeCharge[] @relation("PayoutCharges")
  account             StripeAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([arrivalDate])
}

model StripeBalanceTx {
  id                String        @id @db.VarChar(64)
  accountId         String
  type              String        @db.VarChar(64)
  amount            BigInt
  currency          String        @db.VarChar(8)
  fee               BigInt?
  net               BigInt?
  availableOnUnix   Int?
  createdUnix       Int
  createdAt         DateTime
  reportingCategory String?       @db.VarChar(64)
  sourceId          String?       @db.VarChar(64)
  payoutId          String?       @db.VarChar(64)
  rawJson           Json?
  updatedAt         DateTime      @updatedAt
  account           StripeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([payoutId])
  @@index([sourceId])
  @@index([createdAt])
}

model StripeException {
  id         String    @id @default(cuid())
  kind       String    @db.VarChar(64)
  refId      String?   @db.VarChar(64)
  message    String
  data       Json?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([kind])
  @@index([refId])
}

model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  source    String?

  @@map("waitlist_signups")
}

model QboCompany {
  id        String       @id
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  invoices  QboInvoice[]
  payments  QboPayment[]
  tokens    QboToken?

  @@map("qbo_companies")
}

model QboToken {
  id           String     @id @default(cuid())
  realmId      String     @unique
  accessToken  String
  refreshToken String
  tokenType    String
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  company      QboCompany @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@map("qbo_tokens")
}

model QboInvoice {
  id          String     @id
  realmId     String
  docNumber   String?
  customerRef String?
  total       BigInt
  balance     BigInt
  currency    String     @db.VarChar(8)
  txnDate     DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     QboCompany @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@index([realmId, txnDate])
  @@index([realmId, balance])
  @@map("qbo_invoices")
}

model QboPayment {
  id          String     @id
  realmId     String
  customerRef String?
  total       BigInt
  currency    String     @db.VarChar(8)
  txnDate     DateTime
  appliedTo   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     QboCompany @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@index([realmId, txnDate])
  @@map("qbo_payments")
}

model BankItem {
  id               String   @id @default(cuid())
  institutionName  String
  itemId           String   @unique
  accessToken      String   @unique
  createdAt        DateTime @default(now())

  accounts         BankAccount[]
}

model BankAccount {
  id               String   @id @default(cuid())
  bankItemId       String
  plaidAccountId   String   @unique
  name             String
  officialName     String?
  mask             String?
  subtype          String?
  type             String?
  currency         String    @db.VarChar(8)

  createdAt        DateTime @default(now())

  item             BankItem  @relation(fields: [bankItemId], references: [id], onDelete: Cascade)
  transactions     PlaidTransaction[]

  @@index([bankItemId])
  @@index([plaidAccountId])
}

model PlaidTransaction {
  id               String   @id // Plaid transaction_id
  bankAccountId    String
  date             DateTime
  name             String
  amountMinor      BigInt   // minor units
  currency         String   @db.VarChar(8)
  pending          Boolean
  merchantName     String?
  category         String?
  counterpart      String?
  isoCurrencyCode  String?  // raw field from Plaid if needed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  account          BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  // Optional linking to Stripe payout if matched later:
  matchedPayoutId  String?
  // If you have StripePayout model name different, adjust FK
  // We avoid FK here to keep this additive; linking can be by ID string
  @@index([bankAccountId])
  @@index([date])
  @@index([amountMinor, currency])
  @@index([matchedPayoutId])
}
