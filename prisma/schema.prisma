generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StripePayout {
  id          String   @id @default(cuid())
  stripeId    String   @unique
  amount      BigInt
  currency    String
  status      String
  arrivalDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("stripe_payouts")
}

model StripeCharge {
  id          String   @id @default(cuid())
  stripeId    String   @unique
  amount      BigInt
  currency    String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("stripe_charges")
}

model BankItem {
  id              String        @id @default(cuid())
  institutionName String
  itemId          String        @unique
  accessToken     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        BankAccount[]
  @@map("bank_items")
}

model BankAccount {
  id            String            @id @default(cuid())
  bankItemId    String
  plaidAccountId String           @unique
  name          String
  officialName  String?
  mask          String?
  subtype       String?
  type          String?
  currency      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  bankItem      BankItem          @relation(fields: [bankItemId], references: [id], onDelete: Cascade)
  transactions  PlaidTransaction[]
  @@map("bank_accounts")
}

model PlaidTransaction {
  id              String    @id @default(cuid())
  bankAccountId   String
  date            DateTime
  name            String
  amountMinor     BigInt
  currency        String
  pending         Boolean   @default(false)
  merchantName    String?
  category        String?
  counterpart     String?
  isoCurrencyCode String?
  matchedPayoutId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  @@map("plaid_transactions")
}

model QboToken {
  id           String   @id @default(cuid())
  realmId      String   @unique
  accessToken  String
  refreshToken String
  tokenType    String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("qbo_tokens")
}

model StripeException {
  id      String   @id @default(cuid())
  kind    String
  refId   String
  message String
  data    Json
  createdAt DateTime @default(now())
  @@map("stripe_exceptions")
}
